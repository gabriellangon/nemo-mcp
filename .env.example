# ============================================================
# Nemo — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Transport: "http" for remote access, "stdio" for local
TRANSPORT=http
PORT=3100

# ── Storage Option 1: Supabase (recommended) ──────────────
STORAGE_TYPE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Storage Option 2: Self-Hosted PostgreSQL ──────────────
# STORAGE_TYPE=postgres
# DATABASE_URL=postgresql://nemo:changeme@localhost:5433/nemo

# ── For Docker Compose (self-hosted) ─────────────────────
# DB_PASSWORD=your-secure-password-here

# ── Webhooks (optional) ──────────────────────────────────
# Send events to Make, Zapier, n8n, or any webhook endpoint
#
# Simple mode — single webhook:
# WEBHOOK_URL=https://hook.eu2.make.com/your-scenario-id
# WEBHOOK_EVENTS=*
# WEBHOOK_SECRET=my-shared-secret
#
# Advanced mode — multiple webhooks:
# WEBHOOKS_JSON=[{"url":"https://hook.eu2.make.com/xxx","events":["knowledge.saved","bookmark.saved"],"name":"Make - Notion","secret":"abc"},{"url":"https://hooks.zapier.com/yyy","events":["reminder.created"],"name":"Zapier - Calendar"}]
#
# Webhook settings:
# WEBHOOK_RETRY_ATTEMPTS=2
# WEBHOOK_TIMEOUT_MS=5000
